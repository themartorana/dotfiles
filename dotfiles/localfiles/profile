# All paths we're adding.
# Each line here appends another path
LOCALPATH=${HOME}/bin:${HOME}/.local/bin:${HOME}/.cargo/bin
LOCALPATH=${LOCALPATH}:/opt/homebrew/bin:/opt/homebrew/sbin

# Look locally first
PATH=${LOCALPATH}:${PATH}

# Setup Amazon EC2 Command-Line Tools
export EC2_HOME=${HOME}/.ec2
PATH=${PATH}:${EC2_HOME}/bin

# Export full path
export LOCALPATH
export PATH

# shellcheck disable=SC1091
[[ -f ${HOME}/.profile.local ]] && source "${HOME}/.profile.local"

# XDG Base Directory Specification
# Will not override specifications in .profile.local
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$UID}"

